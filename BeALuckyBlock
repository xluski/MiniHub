local Suffixes = {
    K=1e3,M=1e6,B=1e9,T=1e12,QA=1e15,QI=1e18,SX=1e21,SP=1e24,OC=1e27,NO=1e30
}
local function ParseCashPerSec(str)
    if not str then return 0 end
    str = tostring(str)
    local numPart, suf = str:match("%+?([%d%.]+)(%a*)%$")
    local num = tonumber(numPart) or 0
    if suf and suf ~= "" then
        local mult = Suffixes[suf:upper()]
        if mult then num = num * mult end
    end
    return num
end

