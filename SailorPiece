local function PostWebhook()
    local url = Options.WebhookLink.Value
    if url == "" or not url:find("discord.com/api/webhooks/") then return end
    local selected = Options.WebhookData.Value
    local rarityFilter = Options.WebhookRarity.Value or {}
    local data = Plr.Data
    local lstats = Plr:FindFirstChild("leaderstats")
    local bounty = lstats and lstats:FindFirstChild("Bounty") and lstats.Bounty.Value or 0
    local desc = "### Mini Hub\n"
    if selected["Name"] then desc = desc .. string.format("\n👤 **Player:** ||%s||\n", Plr.Name) end
    if selected["Stats"] then
        local gl = data.Level.Value - StartStats.Level
        local gm = data.Money.Value - StartStats.Money
        local gg = data.Gems.Value - StartStats.Gems
        local gb = bounty - StartStats.Bounty
        desc = desc .. string.format("📈 **Level:** `%s` (+%d)\n", Comma(data.Level.Value), gl)
        desc = desc .. string.format("💰 **Currency:** 💵 %s (+%s) | 💎 %s (+%s)\n", Short(data.Money.Value), Short(gm), Comma(data.Gems.Value), Comma(gg))
        desc = desc .. string.format("☠️ **Bounty:** %s (+%s)\n", Short(bounty), Short(gb))
    end
    desc = desc .. "\n"
    local function IsAllowed(itemName)
        local rarity = Modules.ItemRarity and Modules.ItemRarity.Items[itemName] or "Common"
        return rarityFilter[rarity] == true
    end
    if selected["New Items"] and next(NewItemsBuffer) then
        local filtered = {}
        for name, qty in pairs(NewItemsBuffer) do if IsAllowed(name) then filtered[name] = qty end end
        if next(filtered) then
            desc = desc .. "✨ **New Items**\n```\n"
            for name, qty in pairs(filtered) do desc = desc .. string.format("+ [%d] %s\n", qty, name) end
            desc = desc .. "```\n"
        end
    end
    if selected["All Items"] then
        local filtered = {}
        for _, item in pairs(Shared.Cached.Inv or {}) do if IsAllowed(item.name) then table.insert(filtered, item) end end
        if #filtered > 0 then
            desc = desc .. "🎒 **Inventory**\n```\n"
            for _, item in pairs(filtered) do desc = desc .. string.format("- %s: %s\n", item.name, Comma(item.quantity)) end
            desc = desc .. "```\n"
        end
    end
    local payload = {
        ["embeds"] = {{
            ["description"] = desc,
            ["color"] = tonumber("30ff6a", 16),
            ["footer"] = {["text"] = string.format("Mini Hub • Session: %s • %s", GetSessionTime(), os.date("%x %X"))}
        }}
    }
    if Toggles.PingOnSend.Value then payload["content"] = (Options.DiscordUID.Value ~= "" and "<@"..Options.DiscordUID.Value..">" or "@everyone") end
    task.spawn(function()
        pcall(function()
            request({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload)})
            NewItemsBuffer = {}
        end)
    end)
end

