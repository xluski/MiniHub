Remotes.UpInventory.OnClientEvent:Connect(function(category, data)
    Shared.InventorySynced = true
    if category == "Items" then
        Shared.Cached.Inv = data or {}
        table.clear(Lists.OwnedItem)
        for _, item in pairs(data) do if not table.find(Lists.OwnedItem, item.name) then table.insert(Lists.OwnedItem, item.name) end end
        table.sort(Lists.OwnedItem)
        if Options.TradeItems then Options.TradeItems:SetValues(Lists.OwnedItem) end
    elseif category == "Runes" then
        table.clear(Lists.RuneList)
        table.insert(Lists.RuneList, "None")
        for name, _ in pairs(data) do table.insert(Lists.RuneList, name) end
        table.sort(Lists.RuneList)
        local runeDropdowns = {"DefaultRune","Rune_Mob","Rune_Boss","Rune_BossHP"}
        for _, dd in ipairs(runeDropdowns) do
            if Options[dd] then
                local cur = Options[dd].Value
                Options[dd]:SetValues(Lists.RuneList)
                if cur and cur ~= "" then Options[dd]:SetValue(cur) end
            end
        end
    elseif category == "Accessories" then
        table.clear(Shared.Cached.Accessories)
        if type(data) == "table" then
            for _, accInfo in ipairs(data) do
                if accInfo.name and accInfo.quantity then Shared.Cached.Accessories[accInfo.name] = accInfo.quantity end
            end
        end
        table.clear(Lists.OwnedAccessory)
        local processed = {}
        for _, item in ipairs(data) do
            if (item.enchantLevel or 0) < 10 and not processed[item.name] then
                table.insert(Lists.OwnedAccessory, item.name)
                processed[item.name] = true
            end
        end
        table.sort(Lists.OwnedAccessory)
        if Options.PickEnchant then Options.PickEnchant:SetValues(Lists.OwnedAccessory) end
    elseif category == "Sword" or category == "Melee" then
        Shared.Cached.RawWeapCache[category] = data or {}
        table.clear(Lists.OwnedWeapon)
        local processed = {}
        for _, cat in pairs({"Sword","Melee"}) do
            for _, item in ipairs(Shared.Cached.RawWeapCache[cat]) do
                if (item.blessingLevel or 0) < 10 and not processed[item.name] then
                    table.insert(Lists.OwnedWeapon, item.name)
                    processed[item.name] = true
                end
            end
        end
        table.sort(Lists.OwnedWeapon)
        if Options.PickBlessing then Options.PickBlessing:SetValues(Lists.OwnedWeapon) end
        table.clear(Lists.AllOwnedWeapons)
        local allProcessed = {}
        for _, cat in pairs({"Sword","Melee"}) do
            for _, item in ipairs(Shared.Cached.RawWeapCache[cat]) do
                if not allProcessed[item.name] then table.insert(Lists.AllOwnedWeapons, item.name) allProcessed[item.name] = true end
            end
        end
        table.sort(Lists.AllOwnedWeapons)
        if Options.PassiveWeapon then Options.PassiveWeapon:SetValues(Lists.AllOwnedWeapons) end
    end
end)

