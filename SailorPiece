local function EvalArtifact(uuid, data)
    local actions = {lock = false, delete = false, upgrade = false}
    local function GetFilterStatus(filter, value)
        if not filter or next(filter) == nil then return nil end
        return filter[value] == true
    end
    local function IsWhitelisted(filter, value)
        local status = GetFilterStatus(filter, value)
        if status == nil then return true end
        return status
    end
    local function CountMatches(d, ssFilter)
        local count = 0
        for _, sub in pairs(d.Substats or {}) do if ssFilter[sub.Stat] then count = count + 1 end end
        return count
    end
    if Toggles.ArtifactUpgrade.Value and data.Level < Options.UpgradeCap.Value then
        if IsWhitelisted(Options.UpgradeMS.Value, data.MainStat.Stat) then actions.upgrade = true end
    end
    local lockMinSS = Options.LockMinSS.Value
    if Toggles.ArtifactLock.Value and not data.Locked and data.Level >= (lockMinSS * 3) then
        if IsWhitelisted(Options.LockMS.Value, data.MainStat.Stat) and IsWhitelisted(Options.LockType.Value, data.Category) and IsWhitelisted(Options.LockSet.Value, data.Set) then
            if CountMatches(data, Options.LockSS.Value) >= lockMinSS then actions.lock = true end
        end
    end
    if not data.Locked and not actions.lock then
        if Toggles.DeleteUnlocked.Value then
            actions.delete = true
        elseif Toggles.ArtifactDelete.Value then
            local typeMatch = GetFilterStatus(Options.DelType.Value, data.Category)
            local setMatch = GetFilterStatus(Options.DelSet.Value, data.Set)
            local msDropdown = "DelMS_" .. data.Category
            local specificMS = Options[msDropdown] and Options[msDropdown].Value or {}
            local msMatch = GetFilterStatus(specificMS, data.MainStat.Stat)
            local isTarget = true
            if typeMatch == false then isTarget = false end
            if setMatch == false then isTarget = false end
            if typeMatch == nil and setMatch == nil and msMatch == nil then isTarget = false end
            if isTarget then
                local trashCount = CountMatches(data, Options.DelSS.Value)
                local minTrash = Options.DelMinSS.Value
                local isMaxLevel = data.Level >= Options.UpgradeCap.Value
                if msMatch == true then actions.delete = true
                elseif minTrash == 0 then actions.delete = true
                elseif isMaxLevel and trashCount >= minTrash then actions.delete = true end
            end
        end
    end
    return actions
end

local function AutoEquipBest()
    if not Toggles.ArtifactEquip.Value then return end
    local bestItems = {Helmet=nil,Gloves=nil,Body=nil,Boots=nil}
    local bestScores = {Helmet=-1,Gloves=-1,Body=-1,Boots=-1}
    local targetTypes = Options.EquipType.Value or {}
    local targetMS = Options.EquipMS.Value or {}
    local targetSS = Options.EquipSS.Value or {}
    local function mainStatGood(data)
        if data.Category == "Helmet" or data.Category == "Gloves" then return true end
        return targetMS[data.MainStat.Stat] == true
    end
    local function countMatches(data)
        local count = 0
        for _, sub in pairs(data.Substats or {}) do if targetSS[sub.Stat] then count = count + 1 end end
        return count
    end
    for uuid, data in pairs(Shared.ArtifactSession.Inventory) do
        if targetTypes[data.Category] and mainStatGood(data) then
            local score = (countMatches(data) * 10) + data.Level
            if score > bestScores[data.Category] then bestScores[data.Category] = score bestItems[data.Category] = {UUID=uuid,Equipped=data.Equipped} end
        end
    end
    for _, item in pairs(bestItems) do
        if item and not item.Equipped then Remotes.ArtifactEquip:FireServer(item.UUID) task.wait(0.2) end
    end
end

local function StrictBossMatch(npcName, targetDisplayName)
    local n = npcName:lower():gsub("%s+", "")
