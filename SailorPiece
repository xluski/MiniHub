    discordBtn.MouseButton1Click:Connect(function()
        setclipboard("https://discord.gg/2ezFB7bH5u")
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Mini Hub",
            Text = "Discord link copied! discord.gg/2ezFB7bH5u",
            Duration = 4,
        })
    end)

    local passed = false
    local thread = coroutine.running()

    submitBtn.MouseButton1Click:Connect(function()
        local entered = input.Text:gsub("%s+", "")
        for _, k in ipairs(ValidKeys) do
            if entered == k then
                passed = true
                if typeof(writefile) == "function" then
                    pcall(function()
                        if not isfolder("MiniHub") then makefolder("MiniHub") end
                        writefile(SavedKeyPath, entered)
                    end)
                end
                gui:Destroy()
                coroutine.resume(thread)
                return
            end
        end
        note.Text = "❌ Invalid key. Get yours at discord.gg/2ezFB7bH5u"
        note.TextColor3 = Color3.fromRGB(255, 80, 80)
    end)

    coroutine.yield()
    return passed
end

