-- Connection: notification suppressor
local NotifFrame = PGui:WaitForChild("NotificationUI"):WaitForChild("NotificationsFrame")
local function SuppressNotif(frame)
    task.delay(0.01, function()
        if not Toggles.HideNotifs or not Toggles.HideNotifs.Value then return end
        local txtLabel = frame:FindFirstChild("Txt", true)
        if txtLabel and txtLabel:IsA("TextLabel") then
            local blacklist = {"You don't have this item!", "Not enough "}
            for _, phrase in ipairs(blacklist) do
                if txtLabel.Text:lower():find(phrase:lower()) then frame.Visible = false break end
            end
        end
    end)
end
NotifFrame.ChildAdded:Connect(SuppressNotif)
for _, child in pairs(NotifFrame:GetChildren()) do SuppressNotif(child) end

